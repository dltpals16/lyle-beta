{
  "meta": {
    "description": "난임 커뮤니티 은어/줄임말 → 의학 용어 매핑",
    "purpose": "벡터 DB 검색 시 사용자 입력을 의학 용어로 변환하여 검색 정확도 향상",
    "created": "2026-03-05",
    "version": "1.1.0",
    "note": "블로그 데이터 검증 완료 항목만 포함"
  },
  "exact": {
    "배유제": "배란유도제",
    "돌주사": "프롤루텍스 주사 (프로게스테론)",
    "콩주사": "인트라라피드 주사",
    "멍주사": "크녹산 주사 (GnRH 작용제)",
    "난저": "난소기능저하 (DOR)",
    "난소 나이": "AMH (항뮬러관호르몬)",
    "난소나이": "AMH (항뮬러관호르몬)",
    "화유": "화학적 유산 (Chemical Pregnancy)",
    "통배": "PGT 통과 배아",
    "임테기": "임신테스트기",
    "임테": "임신테스트",
    "숙제": "배란일 맞추기 성관계 (Timed Intercourse)",
    "오픈": "난자 채취 후 수정 확인 (배양 결과)",
    "이식일": "배아 이식일 (ET Day)",
    "더블링": "hCG 더블링 (48시간 내 2배 상승)",
    "클로미": "클로미펜 (Clomiphene)",
    "고날": "고날에프 주사 (FSH 제제)",
    "퓨레곤": "퓨레곤 주사 (FSH 제제)",
    "세트로": "세트로타이드 주사 (GnRH 길항제)",
    "오비드렐": "오비드렐 주사 (hCG 트리거)",
    "데카펩틸": "데카펩틸 주사 (GnRH 작용제)",
    "유트로게스탄": "유트로게스탄 (프로게스테론 경구/질정)",
    "크리논": "크리논 겔 (프로게스테론 질정)",
    "듀파스톤": "듀파스톤 (디드로게스테론)",
    "프로게": "프로게스테론 제제",
    "과자극": "난소과자극증후군 (OHSS)",
    "이노시톨": "이노시톨 (PCOS 보조제)",
    "내막": "자궁내막 (Endometrium)",
    "아기집": "임신낭 (Gestational Sac)",
    "심박": "태아 심박 (Fetal Heart Beat)",
    "리셋": "시술 실패 후 다음 주기 준비",
    "공난포": "공난포 (Empty Follicle Syndrome)",
    "자궁경": "자궁경 검사 (Hysteroscopy)",
    "ERA": "자궁내막 수용성 검사 (Endometrial Receptivity Analysis)",
    "PGT": "착상 전 유전자 검사 (PGT)",
    "해동": "동결배아 해동"
  },
  "patterns": [
    {
      "regex": "신선\\s*(\\d+)차",
      "replacement": "신선배아 이식 {1}회차",
      "example": "신선 2차 → 신선배아 이식 2회차"
    },
    {
      "regex": "동결\\s*(\\d+)차",
      "replacement": "동결배아 이식 {1}회차 (FET)",
      "example": "동결 3차 → 동결배아 이식 3회차 (FET)"
    },
    {
      "regex": "시험관\\s*(\\d+)차",
      "replacement": "체외수정 {1}회차 (IVF)",
      "example": "시험관 2차 → 체외수정 2회차 (IVF)"
    },
    {
      "regex": "인공\\s*(\\d+)차",
      "replacement": "인공수정 {1}회차 (IUI)",
      "example": "인공 3차 → 인공수정 3회차 (IUI)"
    },
    {
      "regex": "([0-9]+)셀",
      "replacement": "{1}세포기 배아",
      "example": "8셀 → 8세포기 배아"
    }
  ]
}
